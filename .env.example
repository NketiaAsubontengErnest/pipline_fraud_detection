# Copy this file to .env and fill in your values.
# The pipeline reads these at startup via os.getenv().

# Kafka broker address.
# Use localhost:9092 when running Python services on the host (default).
# Use kafka:9092 when running Python services inside Docker Compose.
KAFKA_BROKER=localhost:9092

# SQLite database path for live transaction storage.
DB_PATH=Data/transactions.db

# Optional API key to protect POST /api/system-restart.
# Leave blank to disable authentication (any caller can trigger retrain).
RESTART_API_KEY=

# Cooldown in seconds between full pipeline restarts (default: 300 = 5 minutes).
RESTART_COOLDOWN=300

# Set to any non-empty value to disable the background Kafka consumer
# (useful during testing to avoid connection errors when Kafka is not running).
# DISABLE_KAFKA_CONSUMER=1
